# Control-plane HTTP port (Express). The Vite dev server proxies /api here.
CONTROL_PORT=7070

# Where the embedded Grafana dashboard lives (host port mapped from grafana:3000).
GRAFANA_URL=http://localhost:3001/d/incident-lab-main/cloud-incident-lab?orgId=1&kiosk&theme=dark&refresh=10s

# Repo root the control plane runs scripts/docker from.
# Defaults to three levels up from server/ (the lab repo root) when unset.
# REPO_ROOT=/Users/you/Cloud-incident-lab
