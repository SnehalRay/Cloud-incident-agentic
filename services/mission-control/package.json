{
  "name": "mission-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cyborg mission-control UI for the Cloud Incident Lab",
  "scripts": {
    "dev": "concurrently -n SERVER,WEB -c magenta,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc -b --noEmit false --emitDeclarationOnly false || tsc -b",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
