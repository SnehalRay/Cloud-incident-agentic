# ─────────────────────────────────────────────────────────────
# Cloud Incident Lab — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (shared credentials for both shards) ───────────
POSTGRES_DB=incidentlab
POSTGRES_USER=incidentuser
POSTGRES_PASSWORD=changeme

# JDBC URLs for each shard — used by Spring Boot's DatabaseConfig
# Inside Docker, services talk to each other on port 5432 (internal).
# Host machine connects on 5433 (shard-1) and 5434 (shard-2).
DB_SHARD1_URL=jdbc:postgresql://postgres-shard-1:5432/incidentlab
DB_SHARD2_URL=jdbc:postgresql://postgres-shard-2:5432/incidentlab
DB_USER=incidentuser
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Worker ────────────────────────────────────────────────────
WORKER_DATABASE_URL=postgresql://incidentuser:changeme@postgres-shard-1:5432/incidentlab

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
CONSUMER_FAIL_RATE=0.0

# ── Backend API ───────────────────────────────────────────────
BACKEND_PORT=8080

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080
